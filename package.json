{
  "name": "omniguard",
  "version": "0.1.0",
  "description": "Zero-dependency validation, sanitization, hashing, and JWT helpers for TypeScript.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "validation",
    "security",
    "schema",
    "typescript",
    "sanitization",
    "jwt",
    "webcrypto",
    "edge"
  ],
  "author": "Onur Acar",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
